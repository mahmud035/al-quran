# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/al-quran?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — frontend origin allowed to send credentials
CLIENT_ORIGIN=http://localhost:5173
